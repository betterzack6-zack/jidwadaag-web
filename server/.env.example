# Copy this file to ".env" and paste your real PostgreSQL connection string.
# Get a free database at https://neon.tech (or Render/Supabase).
# Example (Neon):
DATABASE_URL=postgresql://USER:PASSWORD@ep-xxxx.eu-central-1.aws.neon.tech/neondb?sslmode=require

# Optional: port for local dev (defaults to 4000)
# PORT=4000
